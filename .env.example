# Copy this file to .env and fill in real values.
# Never commit .env to source control.

# URL of the app under test (default: http://localhost:3000)
BASE_URL=http://localhost:3000

# Credentials for the regular test user
TEST_EMAIL=test@example.com
TEST_PASSWORD=password

# Credentials for the admin test user (used by multi-role setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpassword

# Credentials for the regular role in multi-role setup
USER_EMAIL=user@example.com
USER_PASSWORD=userpassword
